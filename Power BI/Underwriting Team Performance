Total Submissions =
VAR _DynamicsSub =
   CALCULATE (
       COUNTROWS ( Dynamics_opportunities ),
       KEEPFILTERS (
                 Dynamics_opportunities[Stage] <> ("In View")
               ),
       KEEPFILTERS (
                 Dynamics_opportunities[Stage] <> ("In Play")
               ),    
       KEEPFILTERS (
           Dynamics_opportunities[PL_ROI] <> "SME On Line"
       )
   )
 
VAR _BenchmarkSubmissions =
  
       CALCULATE(COUNTROWS ( 'Benchmark NB' ),KEEPFILTERS (
           'Benchmark NB'[Valid Submission]
               IN { "Y" })
       )
 
RETURN
   _DynamicsSub +  _BenchmarkSubmissions
 
Total Submissions PY =
VAR YearsSel =
   VALUES ( 'LK Year'[Year] )
 
VAR YearsPY =
   ADDCOLUMNS (
       YearsSel,
       "PY", [Year] - 1
   )
 
RETURN
   CALCULATE (
       COUNTROWS ( Dynamics_opportunities )
           + COUNTROWS ( 'Benchmark NB' ),
 
       -- Remove existing year/month filters
       REMOVEFILTERS ( 'LK Year' ),
       
 
       -- Apply PY filter correctly
       TREATAS ( SELECTCOLUMNS ( YearsPY, "Year", [PY] ), 'LK Year'[Year] ),
 
       
 
       -- Additional Dynamics filters
       KEEPFILTERS (
           NOT ( Dynamics_opportunities[Stage] IN { "In View", "In Play" } )
       ),
       KEEPFILTERS (
           Dynamics_opportunities[PL_ROI] <> "SME On Line"
       )
   )
 
