Accepted Premium =
VAR _DynamicsPremium =
   CALCULATE (
       SUM ( Dynamics_opportunities[RSA_Quoted_Premium] ),
       KEEPFILTERS (
           Dynamics_opportunities[Stage]
               IN { "Accepted" }
       ),
       KEEPFILTERS (
           Dynamics_opportunities[PL_ROI] <> "SME On Line"
       )
   )
 
VAR _BenchmarkPremium =
   CALCULATE (
       SUM ( 'Benchmark NB'[Premium exc IPT] ),
       KEEPFILTERS (
           'Benchmark NB'[Stage]
               IN { "Accepted" }
       )
   )
 
RETURN
   _DynamicsPremium + _BenchmarkPremium

Accepted Premium PY =
VAR YearsSel =
   VALUES ( 'LK Year'[Year] )
 
VAR YearsPY =
   ADDCOLUMNS (
       YearsSel,
       "PY", [Year] - 1
   )
 
RETURN
   CALCULATE ([Accepted Premium],
 
       -- Remove existing year/month filters
       REMOVEFILTERS ( 'LK Year' ),
       
 
       -- Apply PY filter correctly
       TREATAS ( SELECTCOLUMNS ( YearsPY, "Year", [PY] ), 'LK Year'[Year] )
 
       
   )
 


